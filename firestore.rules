rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: check if user is admin ───────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      
      // PART 1: Initial Registration
      allow create: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.role == 'user';
      
      // PART 2 & 4: Admin Access Request & Approval Logic
      allow update: if request.auth != null && (
        // Users can update their own data but NOT their role
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'appAccess']))
        || 
        // PART 8: Only Admin can Approve/Reject or Change roles
        isAdmin()
      );
    }

    // ─── News ─────────────────────────────────────────────────────────────────
    match /news/{newsId} {
      // Anyone can read published news (public portal)
      allow read: if true;
      // Only admins can create, update, or delete news
      allow write: if isAdmin();
    }

    // ─── Saved News ───────────────────────────────────────────────────────────
    match /saved_news/{savedId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ─── Ads / Advertisements ─────────────────────────────────────────────────
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Notifications (Push) ─────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Categories — English Portal ──────────────────────────────────────────
    match /categories_english/{catId} {
      // Anyone can read (needed for frontend dropdowns too)
      allow read: if true;
      // Only admins can create, update, delete
      allow write: if isAdmin();
    }

    // ─── Categories — Urdu Portal ─────────────────────────────────────────────
    match /categories_urdu/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Media Library ────────────────────────────────────────────────────────
    match /media/{mediaId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── Video Gallery ────────────────────────────────────────────────────────
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── App Settings ─────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

  }
}
